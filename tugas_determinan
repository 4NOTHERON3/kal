    "    print(f\"\\nA6^(-1) = (1/{round(det6)}) * adj(A6):\")\n",
    "    print(np.round(inv6, 6))\n",
    "    print(f\"\\nVerifikasi A6 * A6^(-1) (harus I):\")\n",
    "    print(np.round(A6 @ inv6, 8))\n",
    "else:\n",
    "    print(\"Matriks singular, invers tidak ada!\")"
   ]
  },
